{
  "name": "pi-code-previews",
  "version": "0.1.0",
  "description": "Syntax-highlighted previews for pi tool calls.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "pi-package",
    "pi-extension",
    "syntax-highlighting",
    "code-preview",
    "coding-agent"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattleong/pi-code-previews.git"
  },
  "bugs": {
    "url": "https://github.com/mattleong/pi-code-previews/issues"
  },
  "homepage": "https://github.com/mattleong/pi-code-previews#readme",
  "engines": {
    "node": ">=20"
  },
  "files": [
    "extensions",
    "src",
    "README.md",
    "LICENSE",
    "tsconfig.json"
  ],
  "scripts": {
    "check": "tsc --noEmit",
    "test": "node --import tsx --test tests/*.test.ts",
    "pack:dry": "npm pack --dry-run"
  },
  "dependencies": {
    "diff": "^8.0.4",
    "shiki": "^4.0.2"
  },
  "peerDependencies": {
    "@mariozechner/pi-coding-agent": "*",
    "@mariozechner/pi-tui": "*"
  },
  "pi": {
    "extensions": [
      "./extensions"
    ]
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
